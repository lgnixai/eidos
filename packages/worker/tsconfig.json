{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "baseUrl": ".",
    "emitDeclarationOnly": true,
    "paths": {
      "@/lib/*": [
        "../lib/*"
      ],
      "@/packages/core/*": [
        "../core/*"
      ],
      "@/packages/ai/*": [
        "../ai/*"
      ],
      "@/packages/shared/*": [
        "../shared/*"
      ]
    }
  },
  "include": [
    "./**/*.ts",
    "./**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}