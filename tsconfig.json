{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable",
      "WebWorker"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "allowJs": true,
    "experimentalDecorators": true,
    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    /* Linting */
    "strict": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@/locales/*": [
        "./packages/locales/*"
      ],
      "@/worker/*": [
        "./packages/worker/*"
      ],
      "@/lib/*": [
        "./packages/lib/*"
      ],
      "@/components/*": [
        "./apps/web-app/components/*"
      ],
      "@/hooks/*": [
        "./apps/web-app/hooks/*"
      ],
      "@/styles/*": [
        "./apps/web-app/styles/*"
      ],
      "@/*": [
        "./*"
      ]
    },
    "types": [
      "vite-plugin-pwa/react",
      "node",
      "vitest/globals",
      "vite/client",
      "@types/wicg-file-system-access"
    ]
  },
  "include": [
    "**/*.wasm",
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "prettier.config.cjs",
    "apps/web-app/rag.jsx",
    "scripts/version.cjs",
    "scripts/build-cf-worker.cjs",
    "scripts/notarize.cjs",
    "apps/web-app/postcss.config.mjs",
    "apps/web-app/tailwind.config.mjs",
    "packages/shared/types/**/*.d.ts"
  ],
  "exclude": [
    ".wrangler",
    "node_modules",
    "dist",
    "dev-dist",
    "dist-electron",
    "public",
    "**/node_modules/**",
    "**/dist/**",
    "**/dev-dist/**",
    "**/dist-electron/**"
  ],
  "references": [
    {
      "path": "./tsconfig.node.json"
    },
    {
      "path": "./packages/core"
    },
    {
      "path": "./packages/lib"
    },
    {
      "path": "./packages/v3"
    },
    {
      "path": "./packages/ai"
    },
    {
      "path": "./apps/web-app"
    },
    {
      "path": "./apps/desktop"
    }
  ]
}