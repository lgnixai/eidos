    {
      "path": "../../packages/v3"
    },
    {
      "path": "../../packages/ai"
    },
    {
      "path": "../../packages/core"
    },
    {
      "path": "../../packages/lib"
    },
    {
      "path": "../../packages/worker"
    },
    {
      "path": "../../packages/sandbox"
    }
  ]
