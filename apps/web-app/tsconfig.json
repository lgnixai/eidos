{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "emitDeclarationOnly": true
  },
  "include": [
    "./**/*.ts",
    "./**/*.tsx",
    "./**/*.json",
    "../../apps/desktop/electron/electron-env.d.ts",
