{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "noEmit": false,
    "emitDeclarationOnly": true
  },
  "include": [
    "./**/*.ts",
    "./**/*.tsx",
    "./**/*.json",
    "../../apps/desktop/electron/electron-env.d.ts",
    "../../packages/shared/types/global.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "public/compiled-ui",
    "pages/[database]/extensions/hooks/templates"
  ]
}