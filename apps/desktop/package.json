{
  "name": "eidos",
  "version": "0.23.4",
  "description": "Eidos is an extensible framework for personal data management.",
  "main": "dist-electron/main.js",
  "start": "electron .",
  "type": "module",
  "scripts": {
    "rebuild": "electron-rebuild -f -w @eidos.space/better-sqlite3",
    "postinstall": "electron-builder install-app-deps && node scripts/postinstall-sqlite-ext.cjs",
    "test": "echo \"Error: no test specified\" && exit 1",
    "download-libsimple": "node scripts/download-libsimple.cjs",
    "dev": "cross-env EIDOS_SERVICE_MODE=desktop vite --mode desktop",
    "build": "shx rm -rf dist-electron && cross-env NODE_OPTIONS=--max-old-space-size=8192 EIDOS_SERVICE_MODE=desktop vite build --mode desktop",
    "package": "cross-env BUILD_MODE=1 electron-builder --publish never --config electron/electron-builder.json",
    "package:dev": "cross-env BUILD_MODE=1 electron-builder --publish never --config electron/electron-builder.dev.json"
  },
  "keywords": [],
  "author": "",
  "dependencies": {
    "@eidos.space/better-sqlite3": "^11.9.3",
    "@hono/node-server": "^1.12.2",
    "@libsql/client": "^0.8.1",
    "@types/wicg-file-system-access": "^2023.10.5",
    "aws-sdk": "^2.1526.0",
    "aws4fetch": "^1.0.17",
    "bindings": "^1.5.0",
    "date-fns": "^2.30.0",
    "electron-log": "^5.2.0",
    "electron-updater": "^6.3.9",
    "eventemitter3": "^5.0.1",
    "file-uri-to-path": "^2.0.0",
    "hono": "^4.5.11",
    "native-file-system-adapter": "^3.0.1",
    "oxc-parser": "^0.74.0",
    "oxc-transform": "^0.74.0",
    "sqlite-graft": "^0.1.3",
    "sqlite-vec": "0.1.7-alpha.2",
    "ws": "^8.18.2",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.4.1",
    "@types/ws": "^8.5.5",
    "@vitejs/plugin-react": "^4.6.0",
    "cross-env": "^7.0.3",
    "electron": "^32.3.3",
    "electron-builder": "^24.13.3",
    "electron-notarize": "^1.2.2",
    "electron-rebuild": "^3.2.9",
    "prebuild-install": "^7.1.3",
    "typescript": "^5.3.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-top-level-await": "^1.5.0",
    "vite-plugin-wasm": "^3.4.1",
    "@tailwindcss/postcss": "^4.1.11",
    "@tailwindcss/typography": "^0.5.9",
    "@types/react": "^18.2.14",
    "@types/react-dom": "^18.2.6",
    "@types/react-window": "^1.8.5",
    "@vitejs/plugin-react-oxc": "^0.2.3",
    "autoprefixer": "^10.4.14",
    "clsx": "^1.2.1",
    "postcss": "^8.4.25"
  },
  "license": "ISC",
  "packageManager": "pnpm@10.12.4"
}
